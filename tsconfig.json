{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "node",
    "lib": ["ES2022"],
    "outDir": "./dist",
    "rootDir": "./src",
    "strict": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "noEmit": true,
    "allowJs": true
  },
  "include": ["src/lib/**/*", "src/index.ts", "src/http.ts", "src/http-dev.ts"],
  "exclude": ["src/setup.ts", "api/**/*", "dist/**/*", "node_modules/**/*"]
}
