{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run build:http",
  "rewrites": [
    { "source": "/mcp", "destination": "/api/mcp" },
    { "source": "/mcp/(.*)", "destination": "/api/mcp" }
  ],
  "functions": {
    "api/mcp.ts": {
      "runtime": "edge",
      "memory": 256
    }
  }
}
